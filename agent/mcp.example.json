{
  "mcpServers": {
    "network": {
      "command": "python",
      "args": [
        "src/tools/network/server.py"
      ],
      "description": "Comprehensive network tools: HTTP requests, WHOIS, DNS, subdomain enumeration, IP info, web stack detection",
      "env": {
        "PYTHONPATH": "${PYTHONPATH:-/app/agent/src}"
      }
    },
    "code": {
      "command": "python",
      "args": [
        "src/tools/code/server.py"
      ],
      "description": "Code execution and analysis tools",
      "env": {
        "PYTHONPATH": "${PYTHONPATH:-/app/agent/src}",
        "SPARKY_DB_URL": "${SPARKY_DB_URL}"
      }
    },
    "shell": {
      "command": "python",
      "args": [
        "src/tools/shell/server.py"
      ],
      "description": "Shell command execution tools",
      "env": {
        "PYTHONPATH": "${PYTHONPATH:-/app/agent/src}"
      }
    },
    "update": {
      "command": "python",
      "args": [
        "src/tools/update/server.py"
      ],
      "description": "Update functionality",
      "env": {
        "PYTHONPATH": "${PYTHONPATH:-/app/agent/src}"
      }
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "description": "Fetch URLs and extract page content as markdown (official mcp-server-fetch)"
    },
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ],
      "description": "Current time and timezone conversion (official mcp-server-time)"
    },
    "knowledge": {
      "command": "python",
      "args": [
        "src/tools/knowledge/server.py"
      ],
      "description": "Knowledge graph and memory management",
      "env": {
        "PYTHONPATH": "${PYTHONPATH:-/app/agent/src}",
        "SPARKY_DB_URL": "${SPARKY_DB_URL}"
      }
    },
    "introspection": {
      "command": "python",
      "args": [
        "src/tools/introspection/server.py"
      ],
      "description": "Introspection tools for system and self-monitoring",
      "env": {
        "PYTHONPATH": "${PYTHONPATH:-/app/agent/src}"
      }
    },
    "duckduckgo": {
      "command": "uvx",
      "args": [
        "--from",
        "ddg-search-mcp-Albertous007",
        "ddg-search-mcp"
      ],
      "description": "DuckDuckGo web search via Albertous007/ddg-search-mcp (Lite HTML + curl_cffi TLS impersonation)"
    }
  }
}
